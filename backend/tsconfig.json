{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // /backend/tsconfig.json
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": "./",
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "typeRoots": [
      "./src/types",
      "./node_modules/@types"
    ]
  },
  "include": [
    "src",
    "prisma.config.ts",
    "prisma/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}